#!/bin/sh
# Auto-bump service-worker cache når noe som påvirker offline-cachen er staget.
# Sjekker mot HEAD slik at manuell bump ikke gir dobbel bump.

if ! git diff --cached --name-only --diff-filter=ACMR \
  | grep -qE '\.(html|js|css|svg|json)$|^manifest\.json$'; then
  exit 0
fi

node scripts/bump-cache.js || exit 1
git add service-worker.js
